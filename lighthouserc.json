{
	"ci": {
		"collect": {
			"numberOfRuns": 3,
			"staticDistDir": "./dist",
			"url": ["http://localhost/"],
			"settings": {
				"onlyCategories": ["performance"]
			}
		},
		"assert": {
			"assertions": {
				"categories:performance": [
					"error",
					{
						"minScore": 0.85
					}
				],
				"first-contentful-paint": [
					"warn",
					{
						"maxNumericValue": 1500
					}
				],
				"largest-contentful-paint": [
					"warn",
					{
						"maxNumericValue": 2500
					}
				],
				"total-blocking-time": [
					"warn",
					{
						"maxNumericValue": 200
					}
				],
				"cumulative-layout-shift": [
					"warn",
					{
						"maxNumericValue": 0.1
					}
				]
			}
		},
		"upload": {
			"target": "temporary-public-storage"
		}
	}
}
