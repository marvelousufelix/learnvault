PORT=4000
CORS_ORIGIN=http://localhost:5173

# Optional: Redis for nonce storage + TTL (recommended for production).
# If unset, an in-memory store is used (dev only).
# REDIS_URL=redis://127.0.0.1:6379

# RS256 JWT keys (PEM). Required when NODE_ENV=production.
# In development, keys are auto-generated if omitted (tokens reset on each restart).
# Generate with:
# openssl genrsa -out private.pem 2048
# openssl rsa -in private.pem -pubout -out public.pem
# JWT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
# JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"

# Admin milestone verification
# Comma-separated list of Stellar wallet addresses allowed to approve/reject milestones.
# If unset, any valid JWT is accepted (dev only).
# ADMIN_ADDRESSES=GABC...,GDEF...

# Stellar contract integration
# STELLAR_NETWORK=testnet
# STELLAR_SECRET_KEY=S...
# COURSE_MILESTONE_CONTRACT_ID=C...
