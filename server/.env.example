PINATA_API_KEY=your_pinata_api_key
PINATA_SECRET=your_pinata_secret_api_key

# Optional: override the IPFS HTTP gateway used to construct public URLs.
# Defaults to https://gateway.pinata.cloud/ipfs
# IPFS_GATEWAY_URL=https://your-dedicated-gateway.mypinata.cloud/ipfs
